/* pages/cart/cart.wxss */
.page-cart-wrap {
    background-color: #eee;
    height: 100vh;
    padding: 20rpx;
}

.goods__item {
    background-color: white;
    margin-bottom: 20rpx;
    border-radius: 10rpx;
    padding: 20rpx;
    display: flex;
}
.goods__img {
    width: 130rpx;
    height: 130rpx;
    flex-shrink: 0;
}
.goods__img image {
    width: 100%;
    height: 100%;
}
.goods__detail {
    flex-grow: 1;
    padding-left: 20rpx;
    line-height: 1.25;
    width: 0;
}
.goods__title {
    font-size: 32rpx;
    font-weight: bold;
}
.goods__num {
    color: gray;
    font-size: 24rpx;
}
.goods__desc {
    color: gray;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
}
.goods__bottom {
    margin-top: 10rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    line-height: 38rpx;
}
.goods__amount {
    font-size: 32rpx;
    color: red;
}
.goods__add {
    font-size: 32rpx;
    font-weight: bold;
    border-radius: 50%;
    background-color: #ff9999;
    color: #333333;
    width: 38rpx;
    height: 38rpx;
    text-align: center;
}
